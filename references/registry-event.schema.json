{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aaron-he-zhu/aaron-marketing-skills/references/registry-event.schema.json",
  "title": "Aaron Marketing Registry Event Request v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "upsertPayload": {
      "type": "object",
      "not": {"required": ["transition"]},
      "anyOf": [
        {"required": ["set"], "properties": {"set": {"minProperties": 1}}},
        {"required": ["unset"], "properties": {"unset": {"minItems": 1}}}
      ]
    },
    "transitionPayload": {
      "type": "object",
      "required": ["transition"],
      "not": {"anyOf": [{"required": ["set"]}, {"required": ["unset"]}]}
    },
    "reasonOnlyPayload": {
      "type": "object",
      "required": ["reason"],
      "properties": {"reason": {"minLength": 1}},
      "not": {"anyOf": [
        {"required": ["set"]}, {"required": ["unset"]}, {"required": ["transition"]}
      ]}
    },
    "restorePayload": {
      "type": "object",
      "required": ["reason", "set"],
      "properties": {
        "reason": {"minLength": 1},
        "set": {
          "minProperties": 2,
          "required": ["subscription_status", "basis_ref"],
          "properties": {
            "subscription_status": {"const": "subscribed"},
            "basis_ref": {"type": "string", "minLength": 1}
          }
        }
      },
      "not": {"anyOf": [{"required": ["unset"]}, {"required": ["transition"]}]}
    }
  },
  "required": [
    "schema_version", "idempotency_key", "aggregate_id", "operation",
    "occurred_at", "actor", "authorized_by", "authorization_ref", "source"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "idempotency_key": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "aggregate_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "operation": {"enum": ["propose", "accept", "reject", "upsert", "transition", "tombstone", "suppress", "restore", "erase"]},
    "proposed_operation": {"enum": ["upsert", "transition", "tombstone"]},
    "proposal_event_id": {"type": "string", "format": "uuid"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"enum": ["user", "skill", "system", "data-subject"]},
        "id": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "authorized_by": {"enum": ["user", "data-subject"]},
    "authorization_ref": {"type": "string", "minLength": 1, "maxLength": 256},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref", "observed_at"],
      "properties": {
        "type": {"enum": ["measured", "user-provided", "calculated", "estimated", "proxy"]},
        "ref": {"type": "string", "minLength": 1, "maxLength": 512},
        "observed_at": {
          "type": "string",
          "oneOf": [{"format": "date"}, {"format": "date-time"}]
        }
      }
    },
    "expected_revision": {"type": "integer", "minimum": 0},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "set": {
          "type": "object",
          "propertyNames": {"pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"}
        },
        "unset": {"type": "array", "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"}, "uniqueItems": true},
        "transition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {"from": {"type": ["string", "null"]}, "to": {"type": "string", "minLength": 1}}
        },
        "reason": {"type": "string", "maxLength": 1024}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"operation": {"const": "propose"}}, "required": ["operation"]},
      "then": {"required": ["proposed_operation", "expected_revision", "payload"]},
      "else": {"not": {"required": ["proposed_operation"]}}
    },
    {
      "if": {"properties": {"operation": {"const": "propose"}, "proposed_operation": {"const": "upsert"}}, "required": ["operation", "proposed_operation"]},
      "then": {"properties": {"payload": {"$ref": "#/$defs/upsertPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "propose"}, "proposed_operation": {"const": "transition"}}, "required": ["operation", "proposed_operation"]},
      "then": {"properties": {"payload": {"$ref": "#/$defs/transitionPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "propose"}, "proposed_operation": {"const": "tombstone"}}, "required": ["operation", "proposed_operation"]},
      "then": {"properties": {"payload": {"$ref": "#/$defs/reasonOnlyPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "upsert"}}, "required": ["operation"]},
      "then": {"required": ["expected_revision", "payload"], "properties": {"payload": {"$ref": "#/$defs/upsertPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "transition"}}, "required": ["operation"]},
      "then": {"required": ["expected_revision", "payload"], "properties": {"payload": {"$ref": "#/$defs/transitionPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "tombstone"}}, "required": ["operation"]},
      "then": {"required": ["expected_revision", "payload"], "properties": {"payload": {"$ref": "#/$defs/reasonOnlyPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "suppress"}}, "required": ["operation"]},
      "then": {"required": ["payload"], "properties": {"payload": {"$ref": "#/$defs/reasonOnlyPayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "restore"}}, "required": ["operation"]},
      "then": {"required": ["expected_revision", "payload"], "properties": {"payload": {"$ref": "#/$defs/restorePayload"}}}
    },
    {
      "if": {"properties": {"operation": {"const": "erase"}}, "required": ["operation"]},
      "then": {"required": ["payload"], "properties": {"payload": {"$ref": "#/$defs/reasonOnlyPayload"}}}
    },
    {
      "if": {
        "allOf": [
          {"properties": {"operation": {"const": "erase"}}, "required": ["operation"]},
          {"not": {"properties": {
            "authorized_by": {"const": "data-subject"},
            "actor": {"properties": {"type": {"const": "data-subject"}}, "required": ["type"]}
          }, "required": ["authorized_by", "actor"]}}
        ]
      },
      "then": {"required": ["expected_revision"]}
    },
    {
      "if": {"properties": {"operation": {"enum": ["accept", "reject"]}}, "required": ["operation"]},
      "then": {
        "required": ["proposal_event_id"],
        "not": {"anyOf": [
          {"required": ["expected_revision"]},
          {"properties": {"payload": {"anyOf": [
            {"required": ["set"]}, {"required": ["unset"]}, {"required": ["transition"]}
          ]}}, "required": ["payload"]}
        ]}
      },
      "else": {"not": {"required": ["proposal_event_id"]}}
    },
    {
      "if": {"properties": {"operation": {"const": "reject"}}, "required": ["operation"]},
      "then": {
        "required": ["payload"],
        "properties": {"payload": {"required": ["reason"], "properties": {"reason": {"minLength": 1}}}}
      }
    }
  ]
}
